# ── Required ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://user:password@localhost:5432/mydb

USER_ENDPOINT=https://user-service.example.com/api/users

TOKEN_URL=https://auth.example.com/oauth2/token
CLIENT_ID=my-client-id
CLIENT_SECRET=my-client-secret

# ── Optional (CLI defaults shown) ─────────────────────────────────────────────
START_INTERVAL=30        # days back for earliest window
END_INTERVAL=0           # days back for latest window
INTERVAL_LIMIT=7         # days per API chunk
CHUNK_SLEEP_SECS=60      # pause between chunks
INCLUDE_REALM_TYPES=     # leave empty for all realms
SYNC_SQL=                # optional post-sync SQL
HTTP_TIMEOUT_SECS=600

# ── Logging ───────────────────────────────────────────────────────────────────
RUST_LOG=user_sync=info,sqlx=warn
